rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default deny-all catch-all block
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USER SCHEMAS & ACCESS ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
          && data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 150
          && (data.role == 'organizer' || data.role == 'spectator')
          && (data.favoriteTeamId == null || (data.favoriteTeamId is string && data.favoriteTeamId.size() <= 128))
          && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && isValidId(userId) 
                    && isValidUser(incoming()) 
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId) 
                    && isValidUser(incoming()) 
                    && incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }

    // --- TOURNAMENTS SCHEMAS & ACCESS ---
    function isValidTournament(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.organizerName is string && data.organizerName.size() <= 100
          && data.ownerId is string && data.ownerId.size() <= 128
          && (data.drawType == 'league' || data.drawType == 'knockout' || data.drawType == 'groups')
          && data.participatingTeamIds is list
          && data.teams is list
          && data.players is list
          && data.referees is list
          && data.matches is list
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    match /tournaments/{tournamentId} {
      // Spectators or fans can access any live/saved tournament data for live fan screens
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() 
                    && isValidId(tournamentId) 
                    && incoming().ownerId == request.auth.uid 
                    && isValidTournament(incoming()) 
                    && incoming().createdAt == request.time 
                    && incoming().updatedAt == request.time;

      allow update: if isSignedIn() 
                    && isValidId(tournamentId) 
                    && existing().ownerId == request.auth.uid 
                    && incoming().ownerId == request.auth.uid 
                    && isValidTournament(incoming()) 
                    && incoming().createdAt == existing().createdAt 
                    && incoming().updatedAt == request.time;

      allow delete: if isSignedIn() 
                    && isValidId(tournamentId) 
                    && existing().ownerId == request.auth.uid;
    }
  }
}
